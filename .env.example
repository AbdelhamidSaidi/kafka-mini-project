### MSSQL docker example env file
# Copy this to .env and edit values before running `docker compose up`

# Strong SA password required by the official image
MSSQL_SA_PASSWORD=Your_strong!Passw0rd

# Optional: application DB connection helpers consumed by scripts/generators
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=data_warehouse
MSSQL_UID=your_username
MSSQL_PWD=your_password
MSSQL_TRUSTED=no
